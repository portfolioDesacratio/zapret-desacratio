SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

load_libs() {
    local lib_paths=("$SCRIPT_DIR/lib" "/opt/zapret/lib")

    for path in "${lib_paths[@]}"; do
        if [[ -d "$path" ]]; then
            for lib in "$path"/*.sh; do
                source "$lib"
            done
            return 0
        fi
    done

    echo "Error: Cannot find library files"
    echo "Tried: ${lib_paths[*]}"
    exit 1
}

load_libs
load_config

