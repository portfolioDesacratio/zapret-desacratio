SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

load_libs() {
  local lib_paths=("$SCRIPT_DIR/lib" "/opt/zapret/lib")
  for path in "${lib_paths[@]}"; do
    if [[ -d "$path" ]]; then
      for lib in "$path"/*.sh; do source "$lib"; done
      return 0
    fi
  done
  echo "Error: lib not found in ${lib_paths[*]}"
  exit 1
}

load_libs
load_config

# ─── Баннер ──────────────────────────────────────────────
banner() {
  printf "\n"
  printf "  ${F_FROST2}███████╗ █████╗ ██████╗ ██████╗ ███████╗████████╗${C_RESET}\n"
  printf "  ${F_FROST2}╚══███╔╝██╔══██╗██╔══██╗██╔══██╗██╔════╝╚══██╔══╝${C_RESET}\n"
  printf "  ${F_FROST1}  ███╔╝ ███████║██████╔╝██████╔╝█████╗     ██║   ${C_RESET}\n"
  printf "  ${F_FROST1} ███╔╝  ██╔══██║██╔═══╝ ██╔══██╗██╔══╝     ██║   ${C_RESET}\n"
  printf "  ${F_FROST0}███████╗██║  ██║██║     ██║  ██║███████╗   ██║   ${C_RESET}\n"
  printf "  ${F_FROST0}╚══════╝╚═╝  ╚═╝╚═╝     ╚═╝  ╚═╝╚══════╝   ╚═╝   ${C_RESET}\n"
  printf "  ${F_NORD3}zapret-desacratio · обход DPI${C_RESET}\n"
}

# ─── Главное меню ───────────────────────────────────────
menu() {
  local s
  s=$(get_service_status)
  local st=""
  case "$s" in
    running) st="${SYM_RUNNING} работает" ;;
    stopped) st="${SYM_STOPPED} остановлен" ;;
    enabled) st="${SYM_WARN} включён (не запущен)" ;;
  esac

  printf "\n  ${F_NORD3}статус${C_RESET}  ${st}\n"
  sep

  item 1  "Запуск / Стоп / Рестарт"     "управление сервисом"
  item 2  "Статус"                       "состояние и метрики"
  item 3  "Выбрать стратегию"            "сменить режим обхода"
  item 4  "Своя стратегия"               "создать с нуля"
  item 5  "Править текущую"              "редактор стратегии"
  item 6  "Списки доменов"               "добавить / убрать сайты"
  item 7  "Проверить домен"              "доступен ли сайт"
  item 8  "Тема"                         "сменить раскраску"
  item 9  "Логи"                         "последние записи"
  item 10 "Обновить"                     "стратегии и списки"
  item 11 "Настройки"                    "порты, отладка"
  item 12 "Удалить"                      "полностью снести"
  item 13 "Выход"                        "выйти"
}

# ─── Саб-меню: сервис ───────────────────────────────────
menu_service() {
  clear_screen
  header "Сервис"
  item 1 "Запустить"
  item 2 "Остановить"
  item 3 "Перезапустить"
  item 0 "← Назад"
  footer

  printf "  > "
  read -r c
  case "$c" in
    1) service_start ;;
    2) service_stop ;;
    3) service_restart ;;
    0) return ;;
    *) warn "не, такого нет" ;;
  esac
  [[ "$c" =~ ^[0-3]$ ]] && pause
}

# ─── Логи ───────────────────────────────────────────────
menu_logs() {
  clear_screen
  header "Логи"
  if [[ ! -f "$ZAPRET_LOG" ]]; then
    info "лог не найден: $ZAPRET_LOG"
    footer
    pause
    return
  fi

  local lines=50
  if [[ -r "$ZAPRET_LOG" ]]; then
    tail -n "$lines" "$ZAPRET_LOG" | while IFS= read -r line; do
      printf "  ${F_NORD4}%s${C_RESET}\n" "$line"
    done
  elif cmd_exists sudo; then
    sudo tail -n "$lines" "$ZAPRET_LOG" 2>/dev/null | while IFS= read -r line; do
      printf "  ${F_NORD4}%s${C_RESET}\n" "$line"
    done
  else
    fail "нет доступа к логу"
  fi
  printf "\n"
  dim "последних $lines строк · $ZAPRET_LOG"
  footer
  pause
}

# ─── Настройки ──────────────────────────────────────────
menu_settings() {
  while true; do
    clear_screen
    header "Настройки"

    local as ds
    [[ "$ZAPRET_AUTOSTART" == "true" ]] && as="${F_GREEN}вкл${C_RESET}" || as="${F_RED}выкл${C_RESET}"
    [[ "$ZAPRET_DEBUG" == "true" ]] && ds="${F_YELLOW}вкл${C_RESET}" || ds="${F_NORD3}выкл${C_RESET}"

    printf "\n"
    info "порты          ${F_NORD5}${ZAPRET_PORT_RANGE:-80, 443}${C_RESET}"
    info "отладка        $ds"
    info "автозапуск     $as"
    info "стратегия      ${F_FROST1}${ZAPRET_STRATEGY:-default}${C_RESET}"
    info "тема           ${F_PURPLE}${ZAPRET_THEME:-nord}${C_RESET}"
    printf "\n"

    item 1 "Сменить порты"
    item 2 "Отладка вкл/выкл"
    item 3 "Автозапуск вкл/выкл"
    item 0 "← Назад"
    footer

    printf "  > "
    read -r c

    case "$c" in
      1)
        printf "\n  ${F_NORD3}порты (например 80,443,5228):${C_RESET} "
        read -r ports
        if [[ -n "$ports" ]]; then
          ZAPRET_PORT_RANGE="$ports"
          save_config
          ok "порты → $ports"
          pause
        fi
        ;;
      2)
        [[ "$ZAPRET_DEBUG" == "true" ]] && ZAPRET_DEBUG="false" || ZAPRET_DEBUG="true"
        save_config
        ok "отладка: $ZAPRET_DEBUG"
        pause
        ;;
      3)
        if [[ "$ZAPRET_AUTOSTART" == "true" ]]; then
          ZAPRET_AUTOSTART="false"; service_disable; info "автозапуск выключен"
        else
          ZAPRET_AUTOSTART="true";  service_enable;  info "автозапуск включён"
        fi
        save_config
        pause
        ;;
      0) return ;;
    esac
  done
}

# ─── Цикл ───────────────────────────────────────────────
main() {
  while true; do
    clear_screen
    banner
    menu

    printf "\n  ${F_NORD3}>${C_RESET} "
    read -r c

    case "$c" in
      1) menu_service ;;
      2) clear_screen; show_service_status; pause ;;
      3) clear_screen; list_strategies ;;
      4) clear_screen; create_custom_strategy; pause ;;
      5) clear_screen; edit_current_strategy; pause ;;
      6) show_lists_menu ;;
      7) clear_screen; check_domain ;;
      8) switch_theme ;;
      9) menu_logs ;;
      10) clear_screen; update_strategies; pause ;;
      11) menu_settings ;;
      12)
        clear_screen
        header "Удаление"
        uninstall_zapret
        pause
        ;;
      13|q|Q|exit)
        clear_screen
        ok "пока!"
        exit 0
        ;;
      *) warn "не, такого нет" ; sleep 1 ;;
    esac
  done
}

main "$@"
