    local status
    status=$(get_service_status)
    local status_str=""
    case "$status" in
        running) status_str="${SYM_RUNNING} Работает" ;;
        stopped) status_str="${SYM_STOPPED} Остановлен" ;;
        enabled) status_str="${SYM_WARN} Включён (не запущен)" ;;
    esac

    printf "  ${F_NORD3}Статус:${C_RESET} %s\n\n" "$status_str"

    print_menu_item "1"  "Запуск/Остановка/Перезапуск"  "Управление сервисом zapret"
