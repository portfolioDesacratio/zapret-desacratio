# ═══════════════════════════════════════════════════════════════
# SERVICE CONTROL SUBMENU
# ═══════════════════════════════════════════════════════════════

service_control_menu() {
    clear_screen
    print_line
    print_title "УПРАВЛЕНИЕ СЕРВИСОМ"
    print_line

    printf "\n"
    printf "  ${F_FROST2}${C_BOLD}1)${C_RESET} ${F_NORD6}Запустить${C_RESET}\n"
    printf "  ${F_FROST2}${C_BOLD}2)${C_RESET} ${F_NORD6}Остановить${C_RESET}\n"
    printf "  ${F_FROST2}${C_BOLD}3)${C_RESET} ${F_NORD6}Перезапустить${C_RESET}\n"
    printf "  ${F_FROST2}${C_BOLD}0)${C_RESET} ${F_NORD3}Назад${C_RESET}\n"
    print_footer

    printf "\n  ${F_NORD3}Выбери действие:${C_RESET} "
    read -r choice

    case "$choice" in
        1) service_start ;;
        2) service_stop ;;
        3) service_restart ;;
        0) return ;;
        *) print_warn "Неверный выбор" ;;
    esac
    [[ "$choice" =~ ^[0-3]$ ]] && pause
}

# ═══════════════════════════════════════════════════════════════
# VIEW LOGS
# ═══════════════════════════════════════════════════════════════

view_logs() {
    clear_screen
    print_line
    print_title "ЛОГИ ZAPRET"
    print_line

    if [[ ! -f "$ZAPRET_LOG" ]]; then
        printf "\n"
        print_info "Лог-файл не найден: $ZAPRET_LOG"
        print_footer
        pause
        return
    fi

    local lines=50

    printf "\n"
    if [[ -r "$ZAPRET_LOG" ]]; then
        tail -n "$lines" "$ZAPRET_LOG" | while IFS= read -r line; do
            printf "  ${F_NORD4}%s${C_RESET}\n" "$line"
        done
    else
        if cmd_exists sudo; then
            sudo tail -n "$lines" "$ZAPRET_LOG" 2>/dev/null | while IFS= read -r line; do
                printf "  ${F_NORD4}%s${C_RESET}\n" "$line"
            done
        else
            print_error "Нет доступа к лог-файлу"
        fi
    fi

    printf "\n"
    print_info "Показано последних ${lines} строк: $ZAPRET_LOG"
    print_footer
    pause
}

# ═══════════════════════════════════════════════════════════════
# SETTINGS MENU
# ═══════════════════════════════════════════════════════════════

settings_menu() {
    while true; do
        clear_screen
        print_line
        print_title "НАСТРОЙКИ"
        print_line

        local autostart_str=""
        if [[ "$ZAPRET_AUTOSTART" == "true" ]]; then
            autostart_str="${F_GREEN}Включён${C_RESET}"
        else
            autostart_str="${F_RED}Выключен${C_RESET}"
        fi

        local debug_str=""
        if [[ "$ZAPRET_DEBUG" == "true" ]]; then
            debug_str="${F_YELLOW}Включён${C_RESET}"
        else
            debug_str="${F_NORD3}Выключен${C_RESET}"
        fi

        printf "\n"
        print_status "Порты для обработки:"     "${ZAPRET_PORT_RANGE:-80, 443}"
        print_status "Режим отладки:"           "$debug_str"
        print_status "Автозапуск:"              "$autostart_str"
        print_status "Текущая стратегия:"       "${ZAPRET_STRATEGY:-default}" "$F_FROST1"
        print_status "Тема оформления:"         "${ZAPRET_THEME:-nord}" "$F_PURPLE"

        printf "\n"
        printf "  ${F_FROST2}${C_BOLD}1)${C_RESET} ${F_NORD6}Изменить порты${C_RESET}\n"
        printf "  ${F_FROST2}${C_BOLD}2)${C_RESET} ${F_NORD6}Переключить режим отладки${C_RESET}\n"
        printf "  ${F_FROST2}${C_BOLD}3)${C_RESET} ${F_NORD6}Переключить автозапуск${C_RESET}\n"
        printf "  ${F_FROST2}${C_BOLD}0)${C_RESET} ${F_NORD3}Назад${C_RESET}\n"
        print_footer

        printf "\n  ${F_NORD3}Выбери настройку:${C_RESET} "
        read -r choice

        case "$choice" in
            1)
                printf "\n  ${F_NORD3}Введи порты (например: 80,443,5228):${C_RESET} "
                read -r ports
                if [[ -n "$ports" ]]; then
                    ZAPRET_PORT_RANGE="$ports"
                    save_config
                    print_success "Порты изменены: $ports"
                    pause
                fi
                ;;
            2)
                if [[ "$ZAPRET_DEBUG" == "true" ]]; then
                    ZAPRET_DEBUG="false"
                else
                    ZAPRET_DEBUG="true"
                fi
                save_config
                print_success "Режим отладки: $ZAPRET_DEBUG"
                pause
                ;;
            3)
                if [[ "$ZAPRET_AUTOSTART" == "true" ]]; then
                    ZAPRET_AUTOSTART="false"
                    print_info "Отключение автозапуска..."
                    service_disable
                else
                    ZAPRET_AUTOSTART="true"
                    print_info "Включение автозапуска..."
                    service_enable
                fi
                save_config
                pause
                ;;
            0) return ;;
        esac
    done
}

# ═══════════════════════════════════════════════════════════════
# MAIN LOOP
# ═══════════════════════════════════════════════════════════════

main() {
    while true; do
        clear_screen
        show_banner
        printf "\n"
        show_menu

        printf "\n  ${F_NORD3}Введи номер пункта:${C_RESET} "
        read -r choice

        case "$choice" in
            1)
                service_control_menu
                ;;
            2)
                clear_screen
                show_service_status
                pause
                ;;
            3)
                clear_screen
                list_strategies
                ;;
            4)
                clear_screen
                create_custom_strategy
                pause
                ;;
            5)
                clear_screen
                edit_current_strategy
                pause
                ;;
            6)
                show_lists_menu
                ;;
            7)
                clear_screen
                check_domain
                ;;
            8)
                switch_theme
                ;;
            9)
                view_logs
                ;;
            10)
                clear_screen
                update_strategies
                pause
                ;;
            11)
                settings_menu
                ;;
            12)
                clear_screen
                print_line
                print_title "УДАЛЕНИЕ ZAPRET"
                print_line
                uninstall_zapret
                pause
                ;;
            13|q|Q|exit)
                clear_screen
                print_success "До свидания!"
                exit 0
                ;;
            *)
                print_warn "Неверный выбор. Попробуй снова."
                sleep 1
                ;;
        esac
    done
}

main "$@"
